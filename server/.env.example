# ── Server ────────────────────────────────────────────────────────────
# Port the API listens on. cPanel Passenger sets PORT itself in
# production; this value is for local development.
PORT=3001
# development | production | test
NODE_ENV=development

# ── MySQL ─────────────────────────────────────────────────────────────
# Local dev values match server/docker-compose.dev.yml.
# On cPanel, use the database/user you create under "MySQL Databases"
# (names are usually prefixed, e.g. cpaneluser_farland).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=farland
DB_PASSWORD=farland_dev
DB_NAME=farland

# ── Auth ──────────────────────────────────────────────────────────────
# Secret for signing admin JWTs. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Uploads ───────────────────────────────────────────────────────────
# Directory where admin-uploaded images are written and served from
# (/api/uploads/<file>). Defaults to <server>/uploads in dev. In
# production set this to an absolute path OUTSIDE the deploy folder
# (e.g. /home/cpaneluser/farland-uploads) so redeploys don't wipe media.
UPLOADS_DIR=

# ── First admin user (consumed ONLY by `npm run seed`) ───────────────
# The seed creates this admin with a bcrypt-hashed password if no user
# with this email exists. Change the password after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# ── Email notifications (optional) ────────────────────────────────────
# If SMTP_HOST is empty, enquiry emails are skipped with a logged
# warning — enquiries are still stored in the database.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where new-enquiry notifications are sent.
NOTIFY_EMAIL=
